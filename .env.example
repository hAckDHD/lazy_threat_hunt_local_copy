# Local IOC Intelligence Platform — .env.example
# Copy to .env and fill in values as needed

# Security — set a strong random token to require auth on all API routes
# Generate: openssl rand -hex 32
IOC_API_TOKEN=

# CORS — leave empty to block all cross-origin requests (recommended for local use)
IOC_ALLOWED_ORIGIN=

# Optional enrichment API keys (all optional — tool works without them)
VT_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# Local server port (default: 8847)
IOC_PORT=8847
